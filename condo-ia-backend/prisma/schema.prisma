generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  geminiApiKey String?
  isActive     Boolean  @default(true)
  logoBase64   String?  @db.Text
  rif          String?
  address      String?
  city         String?
  state        String?
  country      String?
  phone        String?
  createdAt    DateTime @default(now())
  
  users        User[]
  units        Unit[]
  expenses     Expense[]
  invoices     Invoice[]
  payments     Payment[]
  auditLogs    AuditLog[]
  announcements Announcement[]
  polls        Poll[]
  messages     Message[]
  knowledgeDocuments KnowledgeDocument[]
}

model User {
  id                 String   @id @default(uuid())
  tenantId           String?
  email              String   @unique
  passwordHash       String
  role               String   // SUPER_ADMIN, ADMIN, or OWNER
  mustChangePassword Boolean  @default(true)
  avatarBase64       String?  @db.Text
  createdAt          DateTime @default(now())

  tenant             Tenant?   @relation(fields: [tenantId], references: [id])
  units              Unit[]
  auditLogs          AuditLog[]
  votes              Vote[]
  messages           Message[]
}

model Unit {
  id               String   @id @default(uuid())
  tenantId         String
  ownerId          String
  unitNumber       String
  aliquotPercentage Float
  isCommercial     Boolean  @default(false)

  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  owner            User     @relation(fields: [ownerId], references: [id])
  invoices         Invoice[]
  payments         Payment[]
}

model Expense {
  id              String   @id @default(uuid())
  tenantId        String
  description     String
  amount          Float
  date            DateTime @default(now())
  isExtraordinary Boolean  @default(false)
  expenseCategory String   @default("MAINTENANCE")
  appliesTo       String   @default("ALL") // "ALL" or "APARTMENTS_ONLY"
  isBilled        Boolean  @default(false)
  providerName    String?
  providerInvoice String?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

model Invoice {
  id          String   @id @default(uuid())
  tenantId    String
  unitId      String
  month       Int
  year        Int
  totalAmount Float
  amountPaid  Float    @default(0)
  status      String   // PENDING, PARTIAL or PAID
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  unit        Unit     @relation(fields: [unitId], references: [id])
}

model Payment {
  id              String   @id @default(uuid())
  tenantId        String
  unitId          String
  amount          Float
  paymentMethod   String   // CARD, TRANSFER, MOVIL
  referenceNumber String?  
  status          String   // PENDING or APPROVED
  ocrConfidence   Float?
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  unit            Unit     @relation(fields: [unitId], references: [id])

  @@unique([tenantId, referenceNumber])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  action      String
  tableName   String
  oldData     String?
  newData     String?
  timestamp   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  text      String
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Poll {
  id        String       @id @default(uuid())
  tenantId  String
  question  String
  createdAt DateTime     @default(now())
  expiresAt DateTime?

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  options   PollOption[]
  votes     Vote[]
}

model PollOption {
  id      String @id @default(uuid())
  pollId  String
  text    String

  poll    Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes   Vote[]
}

model Vote {
  id         String     @id @default(uuid())
  pollId     String
  optionId   String
  userId     String
  createdAt  DateTime   @default(now())

  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option     PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  // Un usuario solo puede votar una vez por cada encuesta
  @@unique([pollId, userId])
}

model KnowledgeDocument {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}
