generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  geminiApiKey String?
  createdAt    DateTime @default(now())
  
  users        User[]
  units        Unit[]
  expenses     Expense[]
  invoices     Invoice[]
  payments     Payment[]
  auditLogs    AuditLog[]
  announcements Announcement[]
  polls        Poll[]
}

model User {
  id                 String   @id @default(uuid())
  tenantId           String
  email              String   @unique
  passwordHash       String
  role               String   // ADMIN or OWNER
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())

  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  units              Unit[]
  auditLogs          AuditLog[]
  votes              Vote[]
}

model Unit {
  id               String   @id @default(uuid())
  tenantId         String
  ownerId          String
  unitNumber       String
  aliquotPercentage Float
  isCommercial     Boolean  @default(false)

  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  owner            User     @relation(fields: [ownerId], references: [id])
  invoices         Invoice[]
}

model Expense {
  id               String   @id @default(uuid())
  tenantId         String
  description      String
  amount           Float
  date             DateTime
  isExtraordinary  Boolean  @default(false)
  expenseCategory  String   // e.g., "Mantenimiento", "Conserjería"
  
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
}

model Invoice {
  id          String   @id @default(uuid())
  tenantId    String
  unitId      String
  month       Int
  year        Int
  totalAmount Float
  status      String   // PENDING or PAID
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  unit        Unit     @relation(fields: [unitId], references: [id])
  payments    Payment[]
}

model Payment {
  id              String   @id @default(uuid())
  tenantId        String
  invoiceId       String
  amount          Float
  paymentMethod   String   // CARD, TRANSFER, MOVIL
  referenceNumber String?  
  status          String   // PENDING or APPROVED
  ocrConfidence   Float?
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  invoice         Invoice  @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, referenceNumber])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  action      String
  tableName   String
  oldData     String?
  newData     String?
  timestamp   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  text      String
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  content   String
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Poll {
  id        String       @id @default(uuid())
  tenantId  String
  question  String
  createdAt DateTime     @default(now())
  expiresAt DateTime?

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  options   PollOption[]
  votes     Vote[]
}

model PollOption {
  id      String @id @default(uuid())
  pollId  String
  text    String

  poll    Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes   Vote[]
}

model Vote {
  id         String     @id @default(uuid())
  pollId     String
  optionId   String
  userId     String
  createdAt  DateTime   @default(now())

  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option     PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  // Un usuario solo puede votar una vez por cada encuesta
  @@unique([pollId, userId])
}
